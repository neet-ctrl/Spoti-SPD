[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Build Info"

[[workflows.workflow]]
name = "Build Info"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo 'Android Project - SPD (Spotify Playlist Downloader). Build via GitHub Actions. See README.md for build instructions.' && tail -f /dev/null"

[workflows.workflow.metadata]
outputType = "console"
