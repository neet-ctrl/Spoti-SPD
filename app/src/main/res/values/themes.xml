<resources>

    <color name="md_theme_light_primary">#96480E</color>
    <color name="md_theme_light_background">#FFFFFBFF</color>

    <color name="md_theme_dark_primary">#FFB68A</color>
    <color name="md_theme_dark_background">#201A17</color>

    <style name="Theme.SpotifyPlaylistDownloader" parent="android:Theme.Material.NoActionBar">
        <item name="android:colorPrimary">@color/md_theme_light_primary</item>
        <item name="android:colorBackground">@color/md_theme_light_background</item>
    </style>

    <style name="Theme.SpotifyPlaylistDownloader.Dialog" parent="android:Theme.Material.Dialog.Alert">
        <item name="android:colorBackground">@color/md_theme_light_background</item>
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
        <item name="android:windowBackground">?android:attr/windowBackground</item>
    </style>
</resources>