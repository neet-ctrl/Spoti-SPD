<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/widget_album_art"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/spd_icon"
            android:scaleType="centerCrop"
            android:background="@drawable/widget_ctrl_btn_bg"
            android:contentDescription="Album Art" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingEnd="6dp">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No song selected"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Library Player"
                android:textColor="#1DB954"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingTop="1dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="3dp">

                <TextView
                    android:id="@+id/widget_queue_pos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/widget_pill_bg"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:text="— / —"
                    android:textColor="#9999BB"
                    android:textSize="9sp" />

                <TextView
                    android:id="@+id/widget_speed_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/widget_speed_bg"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:text="1×"
                    android:textColor="#1DB954"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/widget_favorite"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="5dp"
                android:src="@drawable/ic_favorite_border_widget"
                android:contentDescription="Favorite" />

            <ImageView
                android:id="@+id/widget_refresh"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="5dp"
                android:src="@drawable/ic_refresh_widget"
                android:contentDescription="Refresh Library" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="3dp">

        <TextView
            android:id="@+id/widget_current_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="#9999BB"
            android:textSize="9sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/widget_total_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="#9999BB"
            android:textSize="9sp" />
    </LinearLayout>

    <ProgressBar
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:id="@+id/widget_progress"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:progress="0"
        android:max="100"
        android:indeterminate="false"
        android:progressDrawable="@drawable/widget_progress_drawable"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <ImageView
            android:id="@+id/widget_shuffle"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="5dp"
            android:src="@drawable/ic_shuffle_widget"
            android:contentDescription="Shuffle" />

        <ImageView
            android:id="@+id/widget_seek_backward"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:padding="6dp"
            android:background="@drawable/widget_ctrl_btn_bg"
            android:src="@drawable/ic_fast_rewind_widget"
            android:contentDescription="Seek Backward"
            android:layout_marginStart="4dp" />

        <ImageView
            android:id="@+id/widget_prev"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:padding="7dp"
            android:background="@drawable/widget_ctrl_btn_bg"
            android:src="@drawable/ic_skip_prev_widget"
            android:contentDescription="Previous"
            android:layout_marginStart="4dp" />

        <ImageView
            android:id="@+id/widget_play_pause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="11dp"
            android:background="@drawable/widget_play_btn_bg"
            android:src="@drawable/ic_play_widget"
            android:contentDescription="Play/Pause"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp" />

        <ImageView
            android:id="@+id/widget_next"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:padding="7dp"
            android:background="@drawable/widget_ctrl_btn_bg"
            android:src="@drawable/ic_skip_next_widget"
            android:contentDescription="Next"
            android:layout_marginEnd="4dp" />

        <ImageView
            android:id="@+id/widget_seek_forward"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:padding="6dp"
            android:background="@drawable/widget_ctrl_btn_bg"
            android:src="@drawable/ic_fast_forward_widget"
            android:contentDescription="Seek Forward"
            android:layout_marginEnd="4dp" />

        <ImageView
            android:id="@+id/widget_repeat"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="5dp"
            android:src="@drawable/ic_repeat_widget"
            android:contentDescription="Repeat" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <ImageView
            android:id="@+id/widget_volume_down"
            android:layout_width="28dp"
            android:layout_height="22dp"
            android:padding="3dp"
            android:background="@drawable/widget_vol_btn_bg"
            android:src="@drawable/ic_volume_down_widget"
            android:contentDescription="Volume Down" />

        <ProgressBar
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:id="@+id/widget_volume_bar"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:progress="100"
            android:max="100"
            android:indeterminate="false"
            android:progressTint="#7A7ABB"
            android:backgroundTint="#2A2A3E" />

        <ImageView
            android:id="@+id/widget_volume_up"
            android:layout_width="28dp"
            android:layout_height="22dp"
            android:padding="3dp"
            android:background="@drawable/widget_vol_btn_bg"
            android:src="@drawable/ic_volume_up_widget"
            android:contentDescription="Volume Up" />

        <ImageView
            android:id="@+id/widget_speed"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:padding="3dp"
            android:src="@drawable/ic_speed_widget"
            android:contentDescription="Speed"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@drawable/widget_divider"
        android:layout_marginBottom="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_queue_music_widget"
            android:contentDescription="Queue" />

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Song Queue"
            android:textColor="#1DB954"
            android:textSize="9sp"
            android:textStyle="bold"
            android:paddingStart="4dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_song_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#9999BB"
            android:textSize="9sp" />
    </LinearLayout>

    <ListView
        android:id="@+id/widget_song_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:scrollbars="none"
        android:background="@android:color/transparent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="4dp">

        <TextView
            android:id="@+id/widget_debug_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#444466"
            android:textSize="8sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_copy_log"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Copy Log"
            android:textColor="#666688"
            android:textSize="8sp"
            android:paddingStart="8dp"
            android:paddingEnd="4dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="@drawable/widget_pill_bg" />
    </LinearLayout>

    <ListView
        android:id="@+id/widget_song_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:scrollbars="none"
        android:background="@android:color/transparent" />

</LinearLayout>
