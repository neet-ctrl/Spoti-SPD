<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notification_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="#1A1A2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/notification_icon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/spd_icon"
            android:scaleType="centerCrop"
            android:background="@drawable/widget_ctrl_btn_bg"
            android:contentDescription="Album Art" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="6dp">

            <TextView
                android:id="@+id/notification_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No song selected"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/notification_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Artist"
                android:textColor="#1DB954"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingTop="1dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="3dp">

                <TextView
                    android:id="@+id/notification_subheader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SPD Library"
                    android:textColor="#666688"
                    android:textSize="10sp"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/notification_queue_pos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/widget_pill_bg"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:text=""
                    android:textColor="#9999BB"
                    android:textSize="9sp" />

                <TextView
                    android:id="@+id/notification_speed_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/widget_speed_bg"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:text="1×"
                    android:textColor="#1DB954"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/action_favorite"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:padding="5dp"
                android:src="@drawable/ic_favorite_border_widget"
                android:contentDescription="Favorite" />

            <ImageView
                android:id="@+id/notification_close"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:padding="6dp"
                android:src="@drawable/ic_close_widget"
                android:contentDescription="Close" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="2dp">

        <TextView
            android:id="@+id/notification_current_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="#9999BB"
            android:textSize="10sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/notification_total_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="#9999BB"
            android:textSize="10sp" />
    </LinearLayout>

    <ProgressBar
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:id="@+id/notification_progress"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:progress="0"
        android:max="100"
        android:indeterminate="false"
        android:progressDrawable="@drawable/widget_progress_drawable"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="6dp">

        <ImageView
            android:id="@+id/action_shuffle"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="5dp"
            android:src="@drawable/ic_shuffle_widget"
            android:contentDescription="Shuffle"
            android:layout_marginEnd="2dp" />

        <ImageView
            android:id="@+id/action_seek_backward"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:background="@drawable/widget_ctrl_btn_bg"
            android:src="@drawable/ic_fast_rewind_widget"
            android:contentDescription="Seek Backward"
            android:layout_marginEnd="4dp" />

        <ImageView
            android:id="@+id/action_prev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="7dp"
            android:background="@drawable/widget_ctrl_btn_bg"
            android:src="@drawable/ic_skip_prev_widget"
            android:contentDescription="Previous"
            android:layout_marginEnd="5dp" />

        <ImageView
            android:id="@+id/action_play_pause"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:padding="12dp"
            android:background="@drawable/widget_play_btn_bg"
            android:src="@drawable/ic_play_widget"
            android:contentDescription="Play/Pause"
            android:layout_marginEnd="5dp" />

        <ImageView
            android:id="@+id/action_next"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="7dp"
            android:background="@drawable/widget_ctrl_btn_bg"
            android:src="@drawable/ic_skip_next_widget"
            android:contentDescription="Next"
            android:layout_marginEnd="4dp" />

        <ImageView
            android:id="@+id/action_seek_forward"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:background="@drawable/widget_ctrl_btn_bg"
            android:src="@drawable/ic_fast_forward_widget"
            android:contentDescription="Seek Forward"
            android:layout_marginEnd="2dp" />

        <ImageView
            android:id="@+id/action_repeat"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="5dp"
            android:src="@drawable/ic_repeat_widget"
            android:contentDescription="Repeat" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/action_volume_down"
            android:layout_width="30dp"
            android:layout_height="24dp"
            android:padding="4dp"
            android:background="@drawable/widget_vol_btn_bg"
            android:src="@drawable/ic_volume_down_widget"
            android:contentDescription="Volume Down" />

        <ProgressBar
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:id="@+id/notification_volume_bar"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:progress="100"
            android:max="100"
            android:indeterminate="false"
            android:progressTint="#7A7ABB"
            android:backgroundTint="#2A2A3E" />

        <ImageView
            android:id="@+id/action_volume_up"
            android:layout_width="30dp"
            android:layout_height="24dp"
            android:padding="4dp"
            android:background="@drawable/widget_vol_btn_bg"
            android:src="@drawable/ic_volume_up_widget"
            android:contentDescription="Volume Up" />

        <ImageView
            android:id="@+id/action_speed"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="4dp"
            android:src="@drawable/ic_speed_widget"
            android:contentDescription="Speed"
            android:layout_marginStart="8dp" />

        <ImageView
            android:id="@+id/action_equalizer"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="4dp"
            android:src="@drawable/ic_equalizer_widget"
            android:contentDescription="Equalizer"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/notification_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Library mode"
        android:textColor="#444466"
        android:textSize="9sp"
        android:paddingTop="6dp"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/notification_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:text="Library Player" />
</LinearLayout>
