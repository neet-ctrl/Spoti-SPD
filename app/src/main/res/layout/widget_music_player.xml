<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="#1A1A2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@mipmap/ic_launcher"
            android:background="@drawable/widget_ctrl_btn_bg"
            android:padding="4dp" />

        <TextView
            android:id="@+id/widget_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Library Player"
            android:textColor="#1DB954"
            android:textStyle="bold"
            android:textSize="13sp"
            android:paddingStart="8dp" />

        <ImageView
            android:id="@+id/widget_scan_toggle"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:background="@drawable/widget_ctrl_btn_bg" />

        <ImageView
            android:id="@+id/widget_refresh"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="4dp"
            android:src="@android:drawable/ic_popup_sync"
            android:background="@drawable/widget_ctrl_btn_bg" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/widget_ctrl_btn_bg">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_music_note_widget"
                android:padding="6dp" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingEnd="6dp">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No song selected"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Artist"
                android:textColor="#1DB954"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <ImageView
            android:id="@+id/widget_change_song"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_more"
            android:background="@drawable/widget_ctrl_btn_bg" />
    </LinearLayout>

    <ProgressBar
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:id="@+id/widget_progress"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:progress="0"
        android:max="100"
        android:indeterminate="false"
        android:progressDrawable="@drawable/widget_progress_dot_drawable"
        android:paddingBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="6dp">

        <ImageView
            android:id="@+id/widget_shuffle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:background="@drawable/widget_ctrl_btn_bg" />

        <ImageView
            android:id="@+id/widget_prev"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@drawable/widget_ctrl_btn_bg" />

        <ImageView
            android:id="@+id/widget_play_pause"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_media_play"
            android:background="@drawable/widget_ctrl_btn_bg" />

        <ImageView
            android:id="@+id/widget_next"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:src="@android:drawable/ic_media_next"
            android:background="@drawable/widget_ctrl_btn_bg" />

        <ImageView
            android:id="@+id/widget_repeat"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:background="@drawable/widget_ctrl_btn_bg" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <ImageView
            android:id="@+id/widget_favorite"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="4dp"
            android:src="@android:drawable/btn_star_big_off"
            android:background="@drawable/widget_ctrl_btn_bg" />

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Library mode"
            android:textColor="#666688"
            android:textSize="10sp"
            android:paddingStart="8dp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <ListView
        android:id="@+id/widget_song_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="6dp"
        android:cacheColorHint="#1A1A2E"
        android:divider="@drawable/widget_divider"
        android:dividerHeight="1dp" />
</LinearLayout>
