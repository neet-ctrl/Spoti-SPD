<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="Player icon" />

        <TextView
            android:id="@+id/widget_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Library Player"
            android:textColor="#1DB954"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingStart="10dp" />

        <ImageView
            android:id="@+id/widget_refresh"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:src="@android:drawable/ic_popup_sync"
            android:tint="#FFFFFF"
            android:contentDescription="Refresh" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No song selected"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/widget_artist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Artist"
        android:textColor="#B3B3B3"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingBottom="12dp" />

    <ProgressBar
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:id="@+id/widget_progress"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:progress="0"
        android:max="100"
        android:indeterminate="false"
        android:progressDrawable="@drawable/widget_progress_dot_drawable"
        android:paddingBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/widget_shuffle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:tint="#FFFFFF"
            android:contentDescription="Shuffle" />

        <ImageView
            android:id="@+id/widget_prev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#FFFFFF"
            android:contentDescription="Previous" />

        <ImageView
            android:id="@+id/widget_play_pause"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:padding="10dp"
            android:src="@android:drawable/ic_media_play"
            android:tint="#1DB954"
            android:contentDescription="Play/Pause" />

        <ImageView
            android:id="@+id/widget_next"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_media_next"
            android:tint="#FFFFFF"
            android:contentDescription="Next" />

        <ImageView
            android:id="@+id/widget_repeat"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:tint="#FFFFFF"
            android:contentDescription="Repeat" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/widget_favorite"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="4dp"
            android:src="@android:drawable/btn_star_big_off"
            android:tint="#FFFFFF"
            android:contentDescription="Favorite" />

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Library mode"
            android:textColor="#808080"
            android:textSize="11sp"
            android:paddingStart="10dp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
